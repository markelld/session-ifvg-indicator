//@version=6
indicator("ICT NQ Session Model v2", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────
grpStrat = "Strategy"
grpColor = "Colors"

tz        = input.string("America/New_York", "Timezone")

ifvgBars  = input.int(30, "IFVG Zone Max Bars",    minval=5,  maxval=100, group=grpStrat)
ifvgExt   = input.int(20, "IFVG Zone Extend Bars", minval=1,  maxval=100, group=grpStrat)
extBars   = input.int(5,  "Box Extend Bars",        minval=1,  maxval=20,  group=grpStrat)
rrReward  = input.float(1.0, "Reward",          minval=0.1, step=0.1,  group=grpStrat)
rrRisk    = input.float(1.0, "Risk",            minval=0.1, step=0.1,  group=grpStrat)

bullColor   = input.color(#089981,                "Bull",     group=grpColor)
bearColor   = input.color(#f23645,                "Bear",     group=grpColor)
midColor    = input.color(#787b86,                "Mid",      group=grpColor)
riskColor   = input.color(color.new(#787b86, 80), "Risk Box", group=grpColor)
rewardColor = input.color(color.new(#5b9cf6, 80), "Reward Box", group=grpColor)

// ─────────────────────────────────────────────────────────────────────────────
// SESSION DETECTION
// Asia full:     1900–0000   entry window: 1900–2030
// London full:   0200–0500   entry window: 0200–0330
// NY entry:      0930–1100
// Premarket:     0700–0930
// ─────────────────────────────────────────────────────────────────────────────
inAsia    = not na(time(timeframe.period, "1900-0000", tz))
inLondon  = not na(time(timeframe.period, "0200-0500", tz))
inPre     = not na(time(timeframe.period, "0700-0930", tz))
inAsiaE   = not na(time(timeframe.period, "1900-2030", tz))
inLondonE = not na(time(timeframe.period, "0200-0330", tz))
inNYE     = not na(time(timeframe.period, "0930-1100", tz))
inAnyE    = inAsiaE or inLondonE or inNYE

asiaStart    = inAsia    and not inAsia[1]
londonStart  = inLondon  and not inLondon[1]
preStart     = inPre     and not inPre[1]
asiaEStart   = inAsiaE   and not inAsiaE[1]
londonEStart = inLondonE and not inLondonE[1]
nyEStart     = inNYE     and not inNYE[1]
anyEStart    = asiaEStart or londonEStart or nyEStart

// ─────────────────────────────────────────────────────────────────────────────
// PREV DAY H/L
// ─────────────────────────────────────────────────────────────────────────────
pdHigh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
pdLow  = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_on)

// ─────────────────────────────────────────────────────────────────────────────
// SESSION H/L TRACKING
// ─────────────────────────────────────────────────────────────────────────────
var float asiaH = na
var float asiaL = na
var float lonH  = na
var float lonL  = na
var float preH  = na
var float preL  = na

if asiaStart
    asiaH := high
    asiaL := low
else if inAsia
    asiaH := math.max(nz(asiaH, high), high)
    asiaL := math.min(nz(asiaL,  low),  low)

if londonStart
    lonH := high
    lonL := low
else if inLondon
    lonH := math.max(nz(lonH, high), high)
    lonL := math.min(nz(lonL,  low),  low)

if preStart
    preH := high
    preL := low
else if inPre
    preH := math.max(nz(preH, high), high)
    preL := math.min(nz(preL,  low),  low)

// ─────────────────────────────────────────────────────────────────────────────
// PER-WINDOW STATE — reset at each session entry open
// ─────────────────────────────────────────────────────────────────────────────
var bool  sweptSell   = false
var bool  sweptBuy    = false

var float sweepLow    = na
var float sweepHigh   = na
var float tgtLong     = na
var float tgtShort    = na

var float fvgBearLo   = na
var float fvgBearHi   = na
var int   fvgBearBar  = na

var float fvgBullLo   = na
var float fvgBullHi   = na
var int   fvgBullBar  = na

var bool  bullIFVG     = false
var float bullIFVGlo   = na
var float bullIFVGhi   = na
var int   bullIFVGbar  = na

var bool  bearIFVG     = false
var float bearIFVGlo   = na
var float bearIFVGhi   = na
var int   bearIFVGbar  = na

var bool   longTaken   = false
var bool   shortTaken  = false
var string sess        = "—"

// ── Reset at each session entry open ─────────────────────────────────────────
if anyEStart
    sweptSell    := false
    sweptBuy     := false
    tgtLong      := na
    tgtShort     := na
    fvgBearLo    := na
    fvgBearHi    := na
    fvgBearBar   := na
    fvgBullLo    := na
    fvgBullHi    := na
    fvgBullBar   := na
    bullIFVG     := false
    bullIFVGlo   := na
    bullIFVGhi   := na
    bullIFVGbar  := na
    bearIFVG     := false
    bearIFVGlo   := na
    bearIFVGhi   := na
    bearIFVGbar  := na
    sweepLow     := na
    sweepHigh    := na
    longTaken    := false
    shortTaken   := false
    sess         := asiaEStart ? "Asia" : londonEStart ? "London" : "NY"

// ─────────────────────────────────────────────────────────────────────────────
// REFERENCE LEVELS — prior session H/L for each window
// ─────────────────────────────────────────────────────────────────────────────
refLow  = inAsiaE   ? pdLow  :
          inLondonE ? asiaL  :
          inNYE     ? (not na(lonL) ? lonL : preL) : na

refHigh = inAsiaE   ? pdHigh :
          inLondonE ? asiaH  :
          inNYE     ? (not na(lonH) ? lonH : preH) : na

// ─────────────────────────────────────────────────────────────────────────────
// SWEEP DETECTION — wick through reference level, first sweep per window only
// ─────────────────────────────────────────────────────────────────────────────
sellSweep = inAnyE and not sweptSell and not na(refLow)  and low  < refLow
buySweep  = inAnyE and not sweptBuy  and not na(refHigh) and high > refHigh

if sellSweep
    sweptSell := true
    sweptBuy  := false
    tgtLong   := refHigh

if buySweep
    sweptBuy  := true
    sweptSell := false
    tgtShort  := refLow

if inAnyE and sweptSell
    sweepLow := na(sweepLow) ? low : math.min(sweepLow, low)
if inAnyE and sweptBuy
    sweepHigh := na(sweepHigh) ? high : math.max(sweepHigh, high)

// ─────────────────────────────────────────────────────────────────────────────
// FVG DETECTION — only after a sweep
// ─────────────────────────────────────────────────────────────────────────────
bearFVG = high < low[2]
bullFVG = low  > high[2]

if inAnyE
    if bearFVG and sweptSell
        fvgBearLo  := high
        fvgBearHi  := low[2]
        fvgBearBar := bar_index

    if bullFVG and sweptBuy
        fvgBullLo  := high[2]
        fvgBullHi  := low
        fvgBullBar := bar_index

// ─────────────────────────────────────────────────────────────────────────────
// IFVG ACTIVATION
// ─────────────────────────────────────────────────────────────────────────────
bullIFVGbreak = inAnyE and sweptSell and not na(fvgBearLo) and close > fvgBearLo and not bullIFVG
bearIFVGbreak = inAnyE and sweptBuy  and not na(fvgBullHi) and close < fvgBullHi and not bearIFVG

if bullIFVGbreak
    bullIFVG    := true
    bullIFVGlo  := fvgBearLo
    bullIFVGhi  := fvgBearHi
    bullIFVGbar := bar_index
    bearIFVG    := false
    bearIFVGlo  := na
    bearIFVGhi  := na

if bearIFVGbreak
    bearIFVG    := true
    bearIFVGlo  := fvgBullLo
    bearIFVGhi  := fvgBullHi
    bearIFVGbar := bar_index
    bullIFVG    := false
    bullIFVGlo  := na
    bullIFVGhi  := na

if bullIFVG and not na(bullIFVGbar) and bar_index - bullIFVGbar > ifvgBars
    bullIFVG := false
if bearIFVG and not na(bearIFVGbar) and bar_index - bearIFVGbar > ifvgBars
    bearIFVG := false

// ─────────────────────────────────────────────────────────────────────────────
// ENTRY TRIGGERS
// ─────────────────────────────────────────────────────────────────────────────
longTrigger  = bullIFVG and bar_index > nz(bullIFVGbar, bar_index) and open > bullIFVGlo and open < bullIFVGhi and close > bullIFVGhi
shortTrigger = bearIFVG and bar_index > nz(bearIFVGbar, bar_index) and open > bearIFVGlo and open < bearIFVGhi and close < bearIFVGlo

// ─────────────────────────────────────────────────────────────────────────────
// FINAL SIGNALS
// ─────────────────────────────────────────────────────────────────────────────
longSignal  = inAnyE and sweptSell and longTrigger  and not longTaken  and not na(sweepLow)  and not na(tgtLong)
shortSignal = inAnyE and sweptBuy  and shortTrigger and not shortTaken and not na(sweepHigh) and not na(tgtShort)

longEntry  = bullIFVGhi
longStop   = sweepLow
longTarget = tgtLong

shortEntry  = bearIFVGlo
shortStop   = sweepHigh
shortTarget = tgtShort

longRR  = longEntry  != longStop  ? math.round((longTarget  - longEntry)  / (longEntry  - longStop),  1) : na
shortRR = shortEntry != shortStop ? math.round((shortEntry  - shortTarget) / (shortStop - shortEntry), 1) : na

// ─────────────────────────────────────────────────────────────────────────────
// TRADE VISUALS
// ─────────────────────────────────────────────────────────────────────────────
invis = color.new(color.black, 100)

if longSignal
    bullIFVG := false
    fvgStart = nz(fvgBearBar, bar_index) - 2
    ifvgMid  = (bullIFVGhi + bullIFVGlo) / 2
    box.new(fvgStart, bullIFVGhi, bullIFVGbar, bullIFVGlo, bgcolor=color.new(bearColor, 80), border_color=invis)
    box.new(bullIFVGbar, bullIFVGhi, bar_index + ifvgExt, bullIFVGlo, bgcolor=color.new(bullColor, 80), border_color=invis)
    line.new(fvgStart, bullIFVGhi, bar_index + ifvgExt, bullIFVGhi, color=color.new(chart.fg_color, 50), style=line.style_dashed, width=1)
    line.new(fvgStart, bullIFVGlo, bar_index + ifvgExt, bullIFVGlo, color=color.new(chart.fg_color, 50), style=line.style_dashed, width=1)
    line.new(fvgStart, ifvgMid,    bar_index + ifvgExt, ifvgMid,    color=color.new(midColor, 40),      style=line.style_dashed, width=1)
    label.new(bar_index, low, "●", color=invis, textcolor=bullColor, style=label.style_label_center, size=size.small)
    box.new(chart.point.from_index(bar_index, longStop),   chart.point.from_index(bar_index + extBars, longEntry),  border_color=invis, bgcolor=riskColor)
    box.new(chart.point.from_index(bar_index, longEntry),  chart.point.from_index(bar_index + extBars, longTarget), border_color=invis, bgcolor=rewardColor)
    longTaken := true

if shortSignal
    bearIFVG := false
    fvgStart = nz(fvgBullBar, bar_index) - 2
    ifvgMid  = (bearIFVGhi + bearIFVGlo) / 2
    box.new(fvgStart, bearIFVGhi, bearIFVGbar, bearIFVGlo, bgcolor=color.new(bullColor, 80), border_color=invis)
    box.new(bearIFVGbar, bearIFVGhi, bar_index + ifvgExt, bearIFVGlo, bgcolor=color.new(bearColor, 80), border_color=invis)
    line.new(fvgStart, bearIFVGhi, bar_index + ifvgExt, bearIFVGhi, color=color.new(chart.fg_color, 50), style=line.style_dashed, width=1)
    line.new(fvgStart, bearIFVGlo, bar_index + ifvgExt, bearIFVGlo, color=color.new(chart.fg_color, 50), style=line.style_dashed, width=1)
    line.new(fvgStart, ifvgMid,    bar_index + ifvgExt, ifvgMid,    color=color.new(midColor, 40),      style=line.style_dashed, width=1)
    label.new(bar_index, high, "●", color=invis, textcolor=bearColor, style=label.style_label_center, size=size.small)
    box.new(chart.point.from_index(bar_index, shortEntry),  chart.point.from_index(bar_index + extBars, shortStop),   border_color=invis, bgcolor=riskColor)
    box.new(chart.point.from_index(bar_index, shortTarget), chart.point.from_index(bar_index + extBars, shortEntry),  border_color=invis, bgcolor=rewardColor)
    shortTaken := true

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS — stop_points added for execution system position sizing
// ─────────────────────────────────────────────────────────────────────────────
alertcondition(longSignal,  title="Long Entry (IFVG)",  message="NQ Long: sweep + IFVG retest")
alertcondition(shortSignal, title="Short Entry (IFVG)", message="NQ Short: sweep + IFVG retest")

if longSignal
    longStopPts = math.round(longEntry - longStop)
    alert('{"symbol":"MNQ","session":"' + sess + '","type":"ifvg","dir":"long","entry":' + str.tostring(longEntry, "#.##") + ',"stop":' + str.tostring(longStop, "#.##") + ',"target":' + str.tostring(longTarget, "#.##") + ',"stop_points":' + str.tostring(longStopPts, "#") + ',"rr":' + str.tostring(nz(longRR, 0), "#.#") + '}', alert.freq_once_per_bar)

if shortSignal
    shortStopPts = math.round(shortStop - shortEntry)
    alert('{"symbol":"MNQ","session":"' + sess + '","type":"ifvg","dir":"short","entry":' + str.tostring(shortEntry, "#.##") + ',"stop":' + str.tostring(shortStop, "#.##") + ',"target":' + str.tostring(shortTarget, "#.##") + ',"stop_points":' + str.tostring(shortStopPts, "#") + ',"rr":' + str.tostring(nz(shortRR, 0), "#.#") + '}', alert.freq_once_per_bar)