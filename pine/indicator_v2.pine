//@version=6
indicator("ICT NQ Session Model v2", overlay=true, max_labels_count=300, max_lines_count=300, max_boxes_count=500)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────
grpStrat = "Strategy"
grpColor = "Colors"

tz        = input.string("America/New_York", "Timezone")

ifvgBars  = input.int(30, "IFVG Zone Max Bars", minval=5,  maxval=100, group=grpStrat)
extBars   = input.int(5,  "Box Extend Bars",    minval=1,  maxval=20,  group=grpStrat)
rrReward  = input.float(1.0, "Reward",          minval=0.1, step=0.1,  group=grpStrat)
rrRisk    = input.float(1.0, "Risk",            minval=0.1, step=0.1,  group=grpStrat)

bullColor   = input.color(#089981,                "Bull",       group=grpColor)
bearColor   = input.color(#f23645,                "Bear",       group=grpColor)
midColor    = input.color(#787b86,                "Mid",        group=grpColor)
riskColor   = input.color(color.new(#787b86, 80), "Risk Box",   group=grpColor)
rewardColor = input.color(color.new(#5b9cf6, 80), "Reward Box", group=grpColor)

// ─────────────────────────────────────────────────────────────────────────────
// SESSION DETECTION
// Asia full:     1900–0000   entry window: 1900–2030
// London full:   0200–0500   entry window: 0200–0330
// NY entry:      0930–1100
// Premarket:     0700–0930
// ─────────────────────────────────────────────────────────────────────────────
inAsia    = not na(time(timeframe.period, "1900-0000", tz))
inLondon  = not na(time(timeframe.period, "0200-0500", tz))
inPre     = not na(time(timeframe.period, "0700-0930", tz))
inAsiaE   = not na(time(timeframe.period, "1900-2030", tz))
inLondonE = not na(time(timeframe.period, "0200-0330", tz))
inNYE     = not na(time(timeframe.period, "0930-1100", tz))
inAnyE    = inAsiaE or inLondonE or inNYE

asiaStart    = inAsia    and not inAsia[1]
londonStart  = inLondon  and not inLondon[1]
preStart     = inPre     and not inPre[1]
asiaEStart   = inAsiaE   and not inAsiaE[1]
londonEStart = inLondonE and not inLondonE[1]
nyEStart     = inNYE     and not inNYE[1]
anyEStart    = asiaEStart or londonEStart or nyEStart

// ─────────────────────────────────────────────────────────────────────────────
// PREV DAY H/L
// ─────────────────────────────────────────────────────────────────────────────
pdHigh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
pdLow  = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_on)

// ─────────────────────────────────────────────────────────────────────────────
// SESSION H/L TRACKING
// ─────────────────────────────────────────────────────────────────────────────
var float asiaH = na
var float asiaL = na
var float lonH  = na
var float lonL  = na
var float preH  = na
var float preL  = na

if asiaStart
    asiaH := high
    asiaL := low
else if inAsia
    asiaH := math.max(nz(asiaH, high), high)
    asiaL := math.min(nz(asiaL,  low),  low)

if londonStart
    lonH := high
    lonL := low
else if inLondon
    lonH := math.max(nz(lonH, high), high)
    lonL := math.min(nz(lonL,  low),  low)

if preStart
    preH := high
    preL := low
else if inPre
    preH := math.max(nz(preH, high), high)
    preL := math.min(nz(preL,  low),  low)

// ─────────────────────────────────────────────────────────────────────────────
// SWING PIVOTS — for stop placement
// ─────────────────────────────────────────────────────────────────────────────
var float swingH = na
var float swingL = na

ph = ta.pivothigh(high, 3, 3)
pl = ta.pivotlow(low,  3, 3)

if not na(ph)
    swingH := ph
if not na(pl)
    swingL := pl

// ─────────────────────────────────────────────────────────────────────────────
// PER-WINDOW STATE — reset at each session entry open
// ─────────────────────────────────────────────────────────────────────────────
var bool  sweptSell   = false
var bool  sweptBuy    = false
var float tgtLong     = na
var float tgtShort    = na

// FVG captured post-sweep
var float fvgBearLo   = na
var float fvgBearHi   = na
var int   fvgBearBar  = na

var float fvgBullLo   = na
var float fvgBullHi   = na
var int   fvgBullBar  = na

// Bullish IFVG (inverted from bearish FVG, after sell sweep)
var bool  bullIFVG     = false
var float bullIFVGlo   = na
var float bullIFVGhi   = na
var int   bullIFVGbar  = na
var box   bullIFVGpre  = na
var box   bullIFVGpost = na
var line  bullIFVGlT   = na
var line  bullIFVGlB   = na
var line  bullIFVGlM   = na

// Bearish IFVG (inverted from bullish FVG, after buy sweep)
var bool  bearIFVG     = false
var float bearIFVGlo   = na
var float bearIFVGhi   = na
var int   bearIFVGbar  = na
var box   bearIFVGpre  = na
var box   bearIFVGpost = na
var line  bearIFVGlT   = na
var line  bearIFVGlB   = na
var line  bearIFVGlM   = na

// Breaker Blocks — first displacement candle after sweep
// Bullish breaker: first bearish candle after sell sweep (displacement down → price rallies back into it)
// Bearish breaker: first bullish candle after buy sweep (displacement up → price drops back into it)
var float bbBullHi     = na
var float bbBullLo     = na
var int   bbBullBar    = na
var bool  bbBullActive = false
var box   bbBullBox    = na
var line  bbBullLM     = na

var float bbBearHi     = na
var float bbBearLo     = na
var int   bbBearBar    = na
var bool  bbBearActive = false
var box   bbBearBox    = na
var line  bbBearLM     = na

// Risk/reward boxes
var box   riskBox      = na
var box   rewardBox    = na

var bool   longTaken   = false
var bool   shortTaken  = false
var string sess        = "—"

// ── Reset at each session entry open ──────────────────────────────────────────
if anyEStart
    sweptSell    := false
    sweptBuy     := false
    tgtLong      := na
    tgtShort     := na
    fvgBearLo    := na
    fvgBearHi    := na
    fvgBearBar   := na
    fvgBullLo    := na
    fvgBullHi    := na
    fvgBullBar   := na
    bullIFVG     := false
    bullIFVGlo   := na
    bullIFVGhi   := na
    bullIFVGbar  := na
    bearIFVG     := false
    bearIFVGlo   := na
    bearIFVGhi   := na
    bearIFVGbar  := na
    bbBullHi     := na
    bbBullLo     := na
    bbBullBar    := na
    bbBullActive := false
    bbBearHi     := na
    bbBearLo     := na
    bbBearBar    := na
    bbBearActive := false
    longTaken    := false
    shortTaken   := false
    sess         := asiaEStart ? "Asia" : londonEStart ? "London" : "NY"
    box.delete(bullIFVGpre)
    box.delete(bullIFVGpost)
    box.delete(bearIFVGpre)
    box.delete(bearIFVGpost)
    line.delete(bullIFVGlT)
    line.delete(bullIFVGlB)
    line.delete(bullIFVGlM)
    line.delete(bearIFVGlT)
    line.delete(bearIFVGlB)
    line.delete(bearIFVGlM)
    box.delete(bbBullBox)
    box.delete(bbBearBox)
    line.delete(bbBullLM)
    line.delete(bbBearLM)

// ─────────────────────────────────────────────────────────────────────────────
// REFERENCE LEVELS — prior session H/L for each window
// ─────────────────────────────────────────────────────────────────────────────
refLow  = inAsiaE   ? pdLow  :
          inLondonE ? asiaL  :
          inNYE     ? (not na(lonL) ? lonL : preL) : na

refHigh = inAsiaE   ? pdHigh :
          inLondonE ? asiaH  :
          inNYE     ? (not na(lonH) ? lonH : preH) : na

// ─────────────────────────────────────────────────────────────────────────────
// SWEEP DETECTION — wick through reference level, first sweep per window only
// ─────────────────────────────────────────────────────────────────────────────
sellSweep = inAnyE and not sweptSell and not na(refLow)  and low  < refLow
buySweep  = inAnyE and not sweptBuy  and not na(refHigh) and high > refHigh

if sellSweep
    sweptSell := true
    sweptBuy  := false
    tgtLong   := refHigh

if buySweep
    sweptBuy  := true
    sweptSell := false
    tgtShort  := refLow

// ─────────────────────────────────────────────────────────────────────────────
// FVG DETECTION — only after a sweep
//
// Bearish FVG (gap down):  high < low[2]  → zone: [high, low[2]]
// Bullish FVG (gap up):    low > high[2]  → zone: [high[2], low]
//
// After sell sweep → track bearish FVGs (displacement move)
// After buy sweep  → track bullish FVGs
// ─────────────────────────────────────────────────────────────────────────────
bearFVG = high < low[2]
bullFVG = low  > high[2]

if inAnyE
    if bearFVG and sweptSell
        fvgBearLo  := high
        fvgBearHi  := low[2]
        fvgBearBar := bar_index

    if bullFVG and sweptBuy
        fvgBullLo  := high[2]
        fvgBullHi  := low
        fvgBullBar := bar_index

// ─────────────────────────────────────────────────────────────────────────────
// BREAKER BLOCKS — first displacement candle after sweep
//
// Bullish breaker: first bearish candle after sell sweep
//   → price sweeps low, displaces down, then rallies back into that candle's zone
//   → entry: open in upper half of zone, close above top
//
// Bearish breaker: first bullish candle after buy sweep
//   → price sweeps high, displaces up, then drops back into that candle's zone
//   → entry: open in lower half of zone, close below bottom
// ─────────────────────────────────────────────────────────────────────────────
if inAnyE and sweptSell and not bbBullActive and close < open
    bbBullHi     := high
    bbBullLo     := low
    bbBullBar    := bar_index
    bbBullActive := true
    box.delete(bbBullBox)
    line.delete(bbBullLM)
    _bbBullMid    = (high + low) / 2
    bbBullBox    := box.new(bar_index, high, bar_index + ifvgBars, low, bgcolor=color.new(bullColor, 85), border_color=color.new(bullColor, 50), border_width=1)
    bbBullLM     := line.new(bar_index, _bbBullMid, bar_index + ifvgBars, _bbBullMid, color=color.new(midColor, 50), style=line.style_dashed, width=1)

if inAnyE and sweptBuy and not bbBearActive and close > open
    bbBearHi     := high
    bbBearLo     := low
    bbBearBar    := bar_index
    bbBearActive := true
    box.delete(bbBearBox)
    line.delete(bbBearLM)
    _bbBearMid    = (high + low) / 2
    bbBearBox    := box.new(bar_index, high, bar_index + ifvgBars, low, bgcolor=color.new(bearColor, 85), border_color=color.new(bearColor, 50), border_width=1)
    bbBearLM     := line.new(bar_index, _bbBearMid, bar_index + ifvgBars, _bbBearMid, color=color.new(midColor, 50), style=line.style_dashed, width=1)

// Expire stale breaker blocks
if bbBullActive and not na(bbBullBar) and bar_index - bbBullBar > ifvgBars
    bbBullActive := false
if bbBearActive and not na(bbBearBar) and bar_index - bbBearBar > ifvgBars
    bbBearActive := false

// ─────────────────────────────────────────────────────────────────────────────
// IFVG ACTIVATION
//
// Bullish IFVG: after sell sweep, price closes ABOVE top of bearish FVG
//   → two-part box: bearColor (original FVG period) + bullColor (inverted/live)
//
// Bearish IFVG: after buy sweep, price closes BELOW bottom of bullish FVG
//   → two-part box: bullColor (original) + bearColor (inverted/live)
// ─────────────────────────────────────────────────────────────────────────────
bullIFVGbreak = inAnyE and sweptSell and not na(fvgBearHi) and close > fvgBearHi and not bullIFVG
bearIFVGbreak = inAnyE and sweptBuy  and not na(fvgBullLo) and close < fvgBullLo and not bearIFVG

if bullIFVGbreak
    bullIFVG    := true
    bullIFVGlo  := fvgBearLo
    bullIFVGhi  := fvgBearHi
    bullIFVGbar := bar_index
    bearIFVG    := false
    bearIFVGlo  := na
    bearIFVGhi  := na
    box.delete(bearIFVGpre)
    box.delete(bearIFVGpost)
    line.delete(bearIFVGlT)
    line.delete(bearIFVGlB)
    line.delete(bearIFVGlM)
    box.delete(bullIFVGpre)
    box.delete(bullIFVGpost)
    line.delete(bullIFVGlT)
    line.delete(bullIFVGlB)
    line.delete(bullIFVGlM)
    fvgStart     = nz(fvgBearBar, bar_index) - 2
    ifvgMid      = (fvgBearHi + fvgBearLo) / 2
    invis        = color.new(color.black, 100)
    bullIFVGpre  := box.new(fvgStart, fvgBearHi, bar_index,             fvgBearLo, bgcolor=color.new(bearColor, 80), border_color=invis)
    bullIFVGpost := box.new(bar_index, fvgBearHi, bar_index + ifvgBars, fvgBearLo, bgcolor=color.new(bullColor, 80), border_color=invis)
    bullIFVGlT   := line.new(fvgStart, fvgBearHi, bar_index + ifvgBars, fvgBearHi, color=color.new(chart.fg_color, 50), style=line.style_dashed, width=1)
    bullIFVGlB   := line.new(fvgStart, fvgBearLo, bar_index + ifvgBars, fvgBearLo, color=color.new(chart.fg_color, 50), style=line.style_dashed, width=1)
    bullIFVGlM   := line.new(fvgStart, ifvgMid,   bar_index + ifvgBars, ifvgMid,   color=color.new(midColor, 40),      style=line.style_dashed, width=1)

if bearIFVGbreak
    bearIFVG    := true
    bearIFVGlo  := fvgBullLo
    bearIFVGhi  := fvgBullHi
    bearIFVGbar := bar_index
    bullIFVG    := false
    bullIFVGlo  := na
    bullIFVGhi  := na
    box.delete(bullIFVGpre)
    box.delete(bullIFVGpost)
    line.delete(bullIFVGlT)
    line.delete(bullIFVGlB)
    line.delete(bullIFVGlM)
    box.delete(bearIFVGpre)
    box.delete(bearIFVGpost)
    line.delete(bearIFVGlT)
    line.delete(bearIFVGlB)
    line.delete(bearIFVGlM)
    fvgStart     = nz(fvgBullBar, bar_index) - 2
    ifvgMid      = (fvgBullHi + fvgBullLo) / 2
    invis        = color.new(color.black, 100)
    bearIFVGpre  := box.new(fvgStart, fvgBullHi, bar_index,             fvgBullLo, bgcolor=color.new(bullColor, 80), border_color=invis)
    bearIFVGpost := box.new(bar_index, fvgBullHi, bar_index + ifvgBars, fvgBullLo, bgcolor=color.new(bearColor, 80), border_color=invis)
    bearIFVGlT   := line.new(fvgStart, fvgBullHi, bar_index + ifvgBars, fvgBullHi, color=color.new(chart.fg_color, 50), style=line.style_dashed, width=1)
    bearIFVGlB   := line.new(fvgStart, fvgBullLo, bar_index + ifvgBars, fvgBullLo, color=color.new(chart.fg_color, 50), style=line.style_dashed, width=1)
    bearIFVGlM   := line.new(fvgStart, ifvgMid,   bar_index + ifvgBars, ifvgMid,   color=color.new(midColor, 40),      style=line.style_dashed, width=1)

// Expire stale IFVG zones
if bullIFVG and not na(bullIFVGbar) and bar_index - bullIFVGbar > ifvgBars
    bullIFVG := false
if bearIFVG and not na(bearIFVGbar) and bar_index - bearIFVGbar > ifvgBars
    bearIFVG := false

// ─────────────────────────────────────────────────────────────────────────────
// ENTRY TRIGGERS
//
// IFVG (Unicorn model):
//   Long:  open inside zone, close above top, prior bar touched zone
//   Short: open inside zone, close below bottom, prior bar touched zone
//
// Breaker Block:
//   Long:  open in upper half of bullish breaker zone, close above top
//   Short: open in lower half of bearish breaker zone, close below bottom
//
// bar_index > *bar guard prevents trigger on the same bar the zone was created
// ─────────────────────────────────────────────────────────────────────────────
longTrigger  = bullIFVG and bar_index > nz(bullIFVGbar, bar_index) and close > bullIFVGhi and open < bullIFVGhi and open > bullIFVGlo and math.min(close[1], open[1]) < bullIFVGhi and math.max(close[1], open[1]) > bullIFVGlo

shortTrigger = bearIFVG and bar_index > nz(bearIFVGbar, bar_index) and close < bearIFVGlo and open > bearIFVGlo and open < bearIFVGhi and math.max(close[1], open[1]) > bearIFVGlo and math.min(close[1], open[1]) < bearIFVGhi

bbBullMid = na(bbBullHi) or na(bbBullLo) ? na : (bbBullHi + bbBullLo) / 2
bbBearMid = na(bbBearHi) or na(bbBearLo) ? na : (bbBearHi + bbBearLo) / 2

bbLongTrigger  = bbBullActive and bar_index > nz(bbBullBar, bar_index) and not na(bbBullMid) and open > bbBullMid and open < bbBullHi and close > bbBullHi

bbShortTrigger = bbBearActive and bar_index > nz(bbBearBar, bar_index) and not na(bbBearMid) and open < bbBearMid and open > bbBearLo and close < bbBearLo

// ─────────────────────────────────────────────────────────────────────────────
// FINAL SIGNALS
// ─────────────────────────────────────────────────────────────────────────────
longSignal    = inAnyE and sweptSell and longTrigger    and not longTaken  and not na(swingL) and not na(tgtLong)
shortSignal   = inAnyE and sweptBuy  and shortTrigger   and not shortTaken and not na(swingH) and not na(tgtShort)
bbLongSignal  = inAnyE and sweptSell and bbLongTrigger  and not longTaken  and not na(swingL) and not na(tgtLong)
bbShortSignal = inAnyE and sweptBuy  and bbShortTrigger and not shortTaken and not na(swingH) and not na(tgtShort)

// IFVG entry levels
longEntry   = bullIFVGhi
longStop    = swingL
longTarget  = tgtLong

shortEntry  = bearIFVGlo
shortStop   = swingH
shortTarget = tgtShort

// Breaker block entry levels
bbLongEntry   = bbBullHi
bbLongStop    = swingL
bbLongTarget  = tgtLong

bbShortEntry  = bbBearLo
bbShortStop   = swingH
bbShortTarget = tgtShort

longRR    = longEntry    != longStop    ? math.round((longTarget    - longEntry)    / (longEntry    - longStop),    1) : na
shortRR   = shortEntry   != shortStop   ? math.round((shortEntry    - shortTarget)  / (shortStop    - shortEntry),  1) : na
bbLongRR  = bbLongEntry  != bbLongStop  ? math.round((bbLongTarget  - bbLongEntry)  / (bbLongEntry  - bbLongStop),  1) : na
bbShortRR = bbShortEntry != bbShortStop ? math.round((bbShortEntry  - bbShortTarget) / (bbShortStop - bbShortEntry), 1) : na

// ─────────────────────────────────────────────────────────────────────────────
// TRADE VISUALS — Unicorn model style
//   ● dot at entry bar
//   Risk box:   stop → entry   (gray)
//   Reward box: entry → target (blue)
//   chart.point.from_index anchors boxes — never moves on scroll/zoom
// ─────────────────────────────────────────────────────────────────────────────
if longSignal
    bullIFVG := false
    line.set_x2(bullIFVGlT, bar_index)
    line.set_x2(bullIFVGlB, bar_index)
    line.set_x2(bullIFVGlM, bar_index)
    label.new(bar_index, low, "●", color=color.new(color.black, 100), textcolor=bullColor, style=label.style_label_center, size=size.small)
    box.delete(riskBox)
    box.delete(rewardBox)
    riskBox   := box.new(chart.point.from_index(bar_index, longStop),   chart.point.from_index(bar_index + extBars, longEntry),  border_color=color.new(color.black, 100), bgcolor=riskColor)
    rewardBox := box.new(chart.point.from_index(bar_index, longEntry),  chart.point.from_index(bar_index + extBars, longTarget), border_color=color.new(color.black, 100), bgcolor=rewardColor)
    longTaken := true

if shortSignal
    bearIFVG := false
    line.set_x2(bearIFVGlT, bar_index)
    line.set_x2(bearIFVGlB, bar_index)
    line.set_x2(bearIFVGlM, bar_index)
    label.new(bar_index, high, "●", color=color.new(color.black, 100), textcolor=bearColor, style=label.style_label_center, size=size.small)
    box.delete(riskBox)
    box.delete(rewardBox)
    riskBox   := box.new(chart.point.from_index(bar_index, shortEntry),  chart.point.from_index(bar_index + extBars, shortStop),   border_color=color.new(color.black, 100), bgcolor=riskColor)
    rewardBox := box.new(chart.point.from_index(bar_index, shortTarget), chart.point.from_index(bar_index + extBars, shortEntry),  border_color=color.new(color.black, 100), bgcolor=rewardColor)
    shortTaken := true

if bbLongSignal
    bbBullActive := false
    line.set_x2(bbBullLM, bar_index)
    label.new(bar_index, low, "◆", color=color.new(color.black, 100), textcolor=bullColor, style=label.style_label_center, size=size.small)
    box.delete(riskBox)
    box.delete(rewardBox)
    riskBox   := box.new(chart.point.from_index(bar_index, bbLongStop),   chart.point.from_index(bar_index + extBars, bbLongEntry),  border_color=color.new(color.black, 100), bgcolor=riskColor)
    rewardBox := box.new(chart.point.from_index(bar_index, bbLongEntry),  chart.point.from_index(bar_index + extBars, bbLongTarget), border_color=color.new(color.black, 100), bgcolor=rewardColor)
    longTaken := true

if bbShortSignal
    bbBearActive := false
    line.set_x2(bbBearLM, bar_index)
    label.new(bar_index, high, "◆", color=color.new(color.black, 100), textcolor=bearColor, style=label.style_label_center, size=size.small)
    box.delete(riskBox)
    box.delete(rewardBox)
    riskBox   := box.new(chart.point.from_index(bar_index, bbShortEntry),  chart.point.from_index(bar_index + extBars, bbShortStop),   border_color=color.new(color.black, 100), bgcolor=riskColor)
    rewardBox := box.new(chart.point.from_index(bar_index, bbShortTarget), chart.point.from_index(bar_index + extBars, bbShortEntry),  border_color=color.new(color.black, 100), bgcolor=rewardColor)
    shortTaken := true

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────
alertcondition(longSignal,    title="Long Entry (IFVG)",         message="NQ Long: sweep + IFVG retest")
alertcondition(shortSignal,   title="Short Entry (IFVG)",        message="NQ Short: sweep + IFVG retest")
alertcondition(bbLongSignal,  title="Long Entry (Breaker Block)", message="NQ Long: sweep + breaker block retest")
alertcondition(bbShortSignal, title="Short Entry (Breaker Block)",message="NQ Short: sweep + breaker block retest")

if longSignal
    alert('{"symbol":"' + syminfo.ticker + '","session":"' + sess + '","type":"ifvg","dir":"long","entry":' + str.tostring(longEntry, "#.##") + ',"stop":' + str.tostring(longStop, "#.##") + ',"target":' + str.tostring(longTarget, "#.##") + ',"rr":' + str.tostring(nz(longRR, 0), "#.#") + '}', alert.freq_once_per_bar)

if shortSignal
    alert('{"symbol":"' + syminfo.ticker + '","session":"' + sess + '","type":"ifvg","dir":"short","entry":' + str.tostring(shortEntry, "#.##") + ',"stop":' + str.tostring(shortStop, "#.##") + ',"target":' + str.tostring(shortTarget, "#.##") + ',"rr":' + str.tostring(nz(shortRR, 0), "#.#") + '}', alert.freq_once_per_bar)

if bbLongSignal
    alert('{"symbol":"' + syminfo.ticker + '","session":"' + sess + '","type":"breaker","dir":"long","entry":' + str.tostring(bbLongEntry, "#.##") + ',"stop":' + str.tostring(bbLongStop, "#.##") + ',"target":' + str.tostring(bbLongTarget, "#.##") + ',"rr":' + str.tostring(nz(bbLongRR, 0), "#.#") + '}', alert.freq_once_per_bar)

if bbShortSignal
    alert('{"symbol":"' + syminfo.ticker + '","session":"' + sess + '","type":"breaker","dir":"short","entry":' + str.tostring(bbShortEntry, "#.##") + ',"stop":' + str.tostring(bbShortStop, "#.##") + ',"target":' + str.tostring(bbShortTarget, "#.##") + ',"rr":' + str.tostring(nz(bbShortRR, 0), "#.#") + '}', alert.freq_once_per_bar)
