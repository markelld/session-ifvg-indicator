//@version=6
indicator("Session Sweep IFVG Retest Model - Session Focused", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

//====================================================
// INPUTS
//====================================================
tz               = input.string("America/New_York", "Timezone")
asiaSession      = input.session("2000-0000", "Asia Session")
londonSession    = input.session("0200-0500", "London Session")
premarketSession = input.session("0700-0930", "Premarket Session")
entrySession     = input.session("0930-1030", "Entry Window")

showSessionBg    = input.bool(true, "Show Session Background")
showLevels       = input.bool(true, "Show Session Levels")
showRawFVGs      = input.bool(false, "Show Raw FVG Boxes")
showSweepLabels  = input.bool(false, "Show Sweep Labels")
showTradeVisuals = input.bool(true, "Show Trade Visuals")

pivotLeft        = input.int(2, "Swing Left", minval=1)
pivotRight       = input.int(2, "Swing Right", minval=1)
lineExtendBars   = input.int(12, "Line Extend Bars", minval=3, maxval=40)
zoneExtendBars   = input.int(5, "Zone Extend Bars", minval=2, maxval=20)
reactionLookback = input.int(5, "Fresh FVG Lookback", minval=1, maxval=20)
requireFreshFVG  = input.bool(true, "Require Fresh Same-Direction FVG")
ifvgExpiryBars   = input.int(15, "IFVG Expiry Bars", minval=3, maxval=50)

entryLineColor   = input.color(color.new(color.blue, 0), "Entry Line Color")
stopLineColor    = input.color(color.new(color.red, 0), "Stop Line Color")
targetLineColor  = input.color(color.new(color.teal, 0), "Target Line Color")
zoneColor        = input.color(color.new(color.orange, 80), "Active Zone Color")

//====================================================
// SESSION DETECTION
//====================================================
inAsia      = not na(time(timeframe.period, asiaSession, tz))
inLondon    = not na(time(timeframe.period, londonSession, tz))
inPremarket = not na(time(timeframe.period, premarketSession, tz))
inEntry     = not na(time(timeframe.period, entrySession, tz))

asiaStart      = inAsia and not inAsia[1]
londonStart    = inLondon and not inLondon[1]
premarketStart = inPremarket and not inPremarket[1]

//====================================================
// SESSION HIGHS / LOWS
//====================================================
var float asiaHigh = na
var float asiaLow = na
var float londonHigh = na
var float londonLow = na
var float preHigh = na
var float preLow = na

if asiaStart
    asiaHigh := high
    asiaLow := low
else if inAsia
    asiaHigh := math.max(nz(asiaHigh, high), high)
    asiaLow := math.min(nz(asiaLow, low), low)

if londonStart
    londonHigh := high
    londonLow := low
else if inLondon
    londonHigh := math.max(nz(londonHigh, high), high)
    londonLow := math.min(nz(londonLow, low), low)

if premarketStart
    preHigh := high
    preLow := low
else if inPremarket
    preHigh := math.max(nz(preHigh, high), high)
    preLow := math.min(nz(preLow, low), low)

//====================================================
// STORED FVG STATE
//====================================================
var float latestBullFvgLo = na
var float latestBullFvgHi = na
var int latestBullFvgBar = na

var float latestBearFvgLo = na
var float latestBearFvgHi = na
var int latestBearFvgBar = na

//====================================================
// IFVG STATE
//====================================================
var bool bullIfvgActive = false
var float bullIfvgLo = na
var float bullIfvgHi = na
var int bullIfvgBreakBar = na

var bool bearIfvgActive = false
var float bearIfvgLo = na
var float bearIfvgHi = na
var int bearIfvgBreakBar = na

//====================================================
// SWEEP / TRADE STATE
//====================================================
var bool sellsideSwept = false
var bool buysideSwept = false
var int sellSweepBar = na
var int buySweepBar = na
var bool longTaken = false
var bool shortTaken = false

//====================================================
// DAILY RESET AT PREMARKET START
//====================================================
if premarketStart
    sellsideSwept := false
    buysideSwept := false
    sellSweepBar := na
    buySweepBar := na
    longTaken := false
    shortTaken := false

    bullIfvgActive := false
    bullIfvgLo := na
    bullIfvgHi := na
    bullIfvgBreakBar := na

    bearIfvgActive := false
    bearIfvgLo := na
    bearIfvgHi := na
    bearIfvgBreakBar := na

    latestBullFvgLo := na
    latestBullFvgHi := na
    latestBullFvgBar := na

    latestBearFvgLo := na
    latestBearFvgHi := na
    latestBearFvgBar := na

//====================================================
// SESSION BACKGROUNDS
//====================================================
asiaColor      = showSessionBg and inAsia ? color.new(color.blue, 92) : na
londonColor    = showSessionBg and inLondon ? color.new(color.purple, 93) : na
premarketColor = showSessionBg and inPremarket ? color.new(color.gray, 88) : na
entryColor     = showSessionBg and inEntry ? color.new(color.silver, 84) : na

bgcolor(asiaColor)
bgcolor(londonColor)
bgcolor(premarketColor)
bgcolor(entryColor)

//====================================================
// SESSION LEVELS
//====================================================
plot(showLevels ? asiaHigh : na, "Asia High", color=color.new(color.blue, 10), linewidth=1, style=plot.style_linebr)
plot(showLevels ? asiaLow : na, "Asia Low", color=color.new(color.blue, 10), linewidth=1, style=plot.style_linebr)
plot(showLevels ? londonHigh : na, "London High", color=color.new(color.black, 30), linewidth=1, style=plot.style_linebr)
plot(showLevels ? londonLow : na, "London Low", color=color.new(color.black, 30), linewidth=1, style=plot.style_linebr)
plot(showLevels ? preHigh : na, "Premarket High", color=color.new(color.orange, 10), linewidth=1, style=plot.style_linebr)
plot(showLevels ? preLow : na, "Premarket Low", color=color.new(color.orange, 10), linewidth=1, style=plot.style_linebr)

//====================================================
// HTF BIAS PROXY
//====================================================
htf5Close  = request.security(syminfo.tickerid, "5", close)
htf5Ema20  = request.security(syminfo.tickerid, "5", ta.ema(close, 20))
htf5Ema50  = request.security(syminfo.tickerid, "5", ta.ema(close, 50))

htf15Close = request.security(syminfo.tickerid, "15", close)
htf15Ema20 = request.security(syminfo.tickerid, "15", ta.ema(close, 20))
htf15Ema50 = request.security(syminfo.tickerid, "15", ta.ema(close, 50))

bullBias = htf5Close > htf5Ema20 and htf15Close > htf15Ema20 and htf5Ema20 > htf5Ema50 and htf15Ema20 > htf15Ema50
bearBias = htf5Close < htf5Ema20 and htf15Close < htf15Ema20 and htf5Ema20 < htf5Ema50 and htf15Ema20 < htf15Ema50

//====================================================
// SWING HIGHS / LOWS FOR STOPS
//====================================================
ph = ta.pivothigh(high, pivotLeft, pivotRight)
pl = ta.pivotlow(low, pivotLeft, pivotRight)

var float lastSwingHigh = na
var float lastSwingLow = na

if not na(ph)
    lastSwingHigh := ph

if not na(pl)
    lastSwingLow := pl

//====================================================
// SWEEP LOGIC
//====================================================
sellSweepAsia   = inEntry and not na(asiaLow) and low < asiaLow and close > asiaLow
sellSweepLondon = inEntry and not na(londonLow) and low < londonLow and close > londonLow
sellSweepPre    = inEntry and not na(preLow) and low < preLow and close > preLow

buySweepAsia    = inEntry and not na(asiaHigh) and high > asiaHigh and close < asiaHigh
buySweepLondon  = inEntry and not na(londonHigh) and high > londonHigh and close < londonHigh
buySweepPre     = inEntry and not na(preHigh) and high > preHigh and close < preHigh

if sellSweepAsia or sellSweepLondon or sellSweepPre
    sellsideSwept := true
    sellSweepBar := bar_index
    buysideSwept := false
    buySweepBar := na

if buySweepAsia or buySweepLondon or buySweepPre
    buysideSwept := true
    buySweepBar := bar_index
    sellsideSwept := false
    sellSweepBar := na

plotshape(showSweepLabels and (sellSweepAsia or sellSweepLondon or sellSweepPre), title="Sellside Sweep", style=shape.labelup, location=location.belowbar, text="SSL", color=color.new(color.green, 0), textcolor=color.white, size=size.tiny)
plotshape(showSweepLabels and (buySweepAsia or buySweepLondon or buySweepPre), title="Buyside Sweep", style=shape.labeldown, location=location.abovebar, text="BSL", color=color.new(color.red, 0), textcolor=color.white, size=size.tiny)

//====================================================
// STANDARD FVG DETECTION
//====================================================
bullishFVG = low > high[2]
bearishFVG = high < low[2]

bullFvgLo = high[2]
bullFvgHi = low

bearFvgLo = high
bearFvgHi = low[2]

if bullishFVG and (inPremarket or inEntry)
    latestBullFvgLo := bullFvgLo
    latestBullFvgHi := bullFvgHi
    latestBullFvgBar := bar_index

if bearishFVG and (inPremarket or inEntry)
    latestBearFvgLo := bearFvgLo
    latestBearFvgHi := bearFvgHi
    latestBearFvgBar := bar_index

if showRawFVGs and bullishFVG and (inPremarket or inEntry)
    box.new(bar_index - 2, bullFvgHi, bar_index + 1, bullFvgLo, xloc=xloc.bar_index, bgcolor=color.new(color.green, 85), border_color=color.new(color.green, 0))

if showRawFVGs and bearishFVG and (inPremarket or inEntry)
    box.new(bar_index - 2, bearFvgHi, bar_index + 1, bearFvgLo, xloc=xloc.bar_index, bgcolor=color.new(color.orange, 85), border_color=color.new(color.orange, 0))

//====================================================
// IFVG ACTIVATION
//====================================================
bullInversionBreak = sellsideSwept and not na(sellSweepBar) and bar_index > sellSweepBar and not na(latestBearFvgHi) and close > latestBearFvgHi
if bullInversionBreak
    bullIfvgActive := true
    bullIfvgLo := latestBearFvgLo
    bullIfvgHi := latestBearFvgHi
    bullIfvgBreakBar := bar_index
    bearIfvgActive := false
    bearIfvgLo := na
    bearIfvgHi := na
    bearIfvgBreakBar := na

bearInversionBreak = buysideSwept and not na(buySweepBar) and bar_index > buySweepBar and not na(latestBullFvgLo) and close < latestBullFvgLo
if bearInversionBreak
    bearIfvgActive := true
    bearIfvgLo := latestBullFvgLo
    bearIfvgHi := latestBullFvgHi
    bearIfvgBreakBar := bar_index
    bullIfvgActive := false
    bullIfvgLo := na
    bullIfvgHi := na
    bullIfvgBreakBar := na

//====================================================
// EXPIRE STALE IFVGS
//====================================================
if bullIfvgActive and not na(bullIfvgBreakBar) and bar_index - bullIfvgBreakBar > ifvgExpiryBars
    bullIfvgActive := false
    bullIfvgLo := na
    bullIfvgHi := na
    bullIfvgBreakBar := na

if bearIfvgActive and not na(bearIfvgBreakBar) and bar_index - bearIfvgBreakBar > ifvgExpiryBars
    bearIfvgActive := false
    bearIfvgLo := na
    bearIfvgHi := na
    bearIfvgBreakBar := na

//====================================================
// FRESH REACTION FVG FILTER
//====================================================
recentBullReactionFVG = ta.barssince(bullishFVG) <= reactionLookback
recentBearReactionFVG = ta.barssince(bearishFVG) <= reactionLookback

bullReactionPass = requireFreshFVG ? recentBullReactionFVG : true
bearReactionPass = requireFreshFVG ? recentBearReactionFVG : true

//====================================================
// RETEST OF INVERTED FVG
//====================================================
longRetest = bullIfvgActive and bar_index > nz(bullIfvgBreakBar, bar_index) and low <= bullIfvgHi and high >= bullIfvgLo and close > bullIfvgHi
shortRetest = bearIfvgActive and bar_index > nz(bearIfvgBreakBar, bar_index) and high >= bearIfvgLo and low <= bearIfvgHi and close < bearIfvgLo

//====================================================
// PICK TARGET
//====================================================
f_pickLongTarget(_entry, _h1, _h2, _h3) =>
    float tgt = na
    if not na(_h1) and _h1 > _entry
        tgt := na(tgt) ? _h1 : math.min(tgt, _h1)
    if not na(_h2) and _h2 > _entry
        tgt := na(tgt) ? _h2 : math.min(tgt, _h2)
    if not na(_h3) and _h3 > _entry
        tgt := na(tgt) ? _h3 : math.min(tgt, _h3)
    if na(tgt)
        tgt := math.max(nz(_h1, _entry), math.max(nz(_h2, _entry), nz(_h3, _entry)))
    tgt

f_pickShortTarget(_entry, _l1, _l2, _l3) =>
    float tgt = na
    if not na(_l1) and _l1 < _entry
        tgt := na(tgt) ? _l1 : math.max(tgt, _l1)
    if not na(_l2) and _l2 < _entry
        tgt := na(tgt) ? _l2 : math.max(tgt, _l2)
    if not na(_l3) and _l3 < _entry
        tgt := na(tgt) ? _l3 : math.max(tgt, _l3)
    if na(tgt)
        tgt := math.min(nz(_l1, _entry), math.min(nz(_l2, _entry), nz(_l3, _entry)))
    tgt

//====================================================
// FINAL ENTRY CONDITIONS
//====================================================
longSignal = inEntry and sellsideSwept and bullBias and bullReactionPass and longRetest and not longTaken and not na(lastSwingLow)
shortSignal = inEntry and buysideSwept and bearBias and bearReactionPass and shortRetest and not shortTaken and not na(lastSwingHigh)

//====================================================
// ENTRY / STOP / TARGET VALUES
//====================================================
longEntry = close
longStop = lastSwingLow
longTarget = f_pickLongTarget(longEntry, asiaHigh, londonHigh, preHigh)

shortEntry = close
shortStop = lastSwingHigh
shortTarget = f_pickShortTarget(shortEntry, asiaLow, londonLow, preLow)

//====================================================
// TRADE VISUALS
//====================================================
var box activeZoneBox = na
var line activeEntryLine = na
var line activeStopLine = na
var line activeTargetLine = na
var label activeEntryLabel = na
var label activeStopLabel = na
var label activeTargetLabel = na

f_clearDrawings() =>
    if not na(activeZoneBox)
        box.delete(activeZoneBox)
    if not na(activeEntryLine)
        line.delete(activeEntryLine)
    if not na(activeStopLine)
        line.delete(activeStopLine)
    if not na(activeTargetLine)
        line.delete(activeTargetLine)
    if not na(activeEntryLabel)
        label.delete(activeEntryLabel)
    if not na(activeStopLabel)
        label.delete(activeStopLabel)
    if not na(activeTargetLabel)
        label.delete(activeTargetLabel)

if longSignal and showTradeVisuals
    f_clearDrawings()
    activeZoneBox := box.new(bar_index - 1, bullIfvgHi, bar_index + zoneExtendBars, bullIfvgLo, xloc=xloc.bar_index, bgcolor=zoneColor, border_color=color.new(color.orange, 0))
    activeEntryLine := line.new(bar_index, longEntry, bar_index + lineExtendBars, longEntry, xloc=xloc.bar_index, color=entryLineColor, width=2)
    activeStopLine := line.new(bar_index, longStop, bar_index + lineExtendBars, longStop, xloc=xloc.bar_index, color=stopLineColor, width=2)
    activeTargetLine := line.new(bar_index, longTarget, bar_index + lineExtendBars, longTarget, xloc=xloc.bar_index, color=targetLineColor, width=2)
    activeEntryLabel := label.new(bar_index, longEntry, "Entry", style=label.style_label_left, textcolor=color.white, color=color.new(entryLineColor, 20))
    activeStopLabel := label.new(bar_index, longStop, "Stop Loss", style=label.style_label_left, textcolor=color.white, color=color.new(stopLineColor, 20))
    activeTargetLabel := label.new(bar_index, longTarget, "Target", style=label.style_label_left, textcolor=color.white, color=color.new(targetLineColor, 20))
    longTaken := true

if shortSignal and showTradeVisuals
    f_clearDrawings()
    activeZoneBox := box.new(bar_index - 1, bearIfvgHi, bar_index + zoneExtendBars, bearIfvgLo, xloc=xloc.bar_index, bgcolor=zoneColor, border_color=color.new(color.orange, 0))
    activeEntryLine := line.new(bar_index, shortEntry, bar_index + lineExtendBars, shortEntry, xloc=xloc.bar_index, color=entryLineColor, width=2)
    activeStopLine := line.new(bar_index, shortStop, bar_index + lineExtendBars, shortStop, xloc=xloc.bar_index, color=stopLineColor, width=2)
    activeTargetLine := line.new(bar_index, shortTarget, bar_index + lineExtendBars, shortTarget, xloc=xloc.bar_index, color=targetLineColor, width=2)
    activeEntryLabel := label.new(bar_index, shortEntry, "Entry", style=label.style_label_left, textcolor=color.white, color=color.new(entryLineColor, 20))
    activeStopLabel := label.new(bar_index, shortStop, "Stop Loss", style=label.style_label_left, textcolor=color.white, color=color.new(stopLineColor, 20))
    activeTargetLabel := label.new(bar_index, shortTarget, "Target", style=label.style_label_left, textcolor=color.white, color=color.new(targetLineColor, 20))
    shortTaken := true

plotshape(longSignal, title="Long Entry", style=shape.triangleup, location=location.belowbar, color=color.new(color.teal, 0), size=size.small, text="LONG")
plotshape(shortSignal, title="Short Entry", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.small, text="SHORT")

//====================================================
// ALERTS
//====================================================
alertcondition(longSignal, title="Long Entry", message="Long setup: sellside sweep + bullish IFVG retest + HTF bias aligned")
alertcondition(shortSignal, title="Short Entry", message="Short setup: buyside sweep + bearish IFVG retest + HTF bias aligned")